{
  "name": "chat-package",
  "version": "1.0.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./index.css": "./dist/index.css"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist && npx @tailwindcss/cli -i ./src/styles.css -o ./dist/index.css",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@assistant-ui/react": "^0.12.15",
    "@assistant-ui/react-data-stream": "^0.12.0",
    "@assistant-ui/react-ui": "^0.2.1",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.470.0",
    "tailwind-merge": "^2.0.0"
  },
  "homepage": "https://github.com/bencrane/chat-package#readme",
  "description": "",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
